# ══════════════════════════════════════════════════════════════════════════════
# HCC Agent — Production Environment Variables
# Copy this file, fill in values, and set in Digital Ocean App Platform
# ⚠️  NEVER commit actual .env files to git
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://YOUR-DO-APP-DOMAIN.ondigitalocean.app

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://wkyzejotrcraluextvpc.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=rk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here

# PRODUCTION WEBHOOK SECRET — NOT the CLI local secret (whsec_93550...)
# Generate this by adding a new webhook in Stripe Dashboard:
# → https://dashboard.stripe.com/webhooks → Add endpoint
# → URL: https://YOUR-DO-DOMAIN/api/pickleball/webhook
# → Events: checkout.session.completed
# → Copy the Signing secret shown after creation
STRIPE_WEBHOOK_SECRET=whsec_your_production_secret_here

# ── Gmail ─────────────────────────────────────────────────────────────────────
GMAIL_USER=knoxvillehcc@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Odoo (if using) ───────────────────────────────────────────────────────────
ODOO_URL=https://knoxhcc.odoo.com
ODOO_DB=knoxhcc
ODOO_USERNAME=your_odoo_email@domain.com
ODOO_PASSWORD=your_odoo_password
